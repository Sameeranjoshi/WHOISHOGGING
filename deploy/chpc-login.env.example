CHPC_COLLECTOR_MODE=local
CHPC_GPU_FINDER_HOST=127.0.0.1
CHPC_GPU_FINDER_PORT=8000
CHPC_GPU_FINDER_REFRESH_INTERVAL=300
CHPC_SCRIPT_TIMEOUT_SECONDS=180

# Set this only when a static frontend hosted on another origin calls this backend.
# Example: CHPC_GPU_FINDER_ALLOWED_ORIGINS=https://sameeranjoshi.github.io
# CHPC_GPU_FINDER_ALLOWED_ORIGINS=

# Optional direct HTTPS support. If you use an SSH tunnel or VS Code port forwarding,
# leave these empty and let the tunnel/frontend provide HTTPS.
# CHPC_GPU_FINDER_TLS_CERT=$HOME/chpc-gpu-finder/certs/fullchain.pem
# CHPC_GPU_FINDER_TLS_KEY=$HOME/chpc-gpu-finder/certs/privkey.pem
